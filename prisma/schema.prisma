generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
}

model User{
  id          String @id @default(uuid())
  name        String
  email       String @unique
  password    String

  createdAt   DateTime @default(now())
}
model Movie {
  id          String      @id @default(uuid())
  title       String
  overview    String?
  director    String?
  releaseYear Int?
  genres      String[] @default([])
  runtime     Int?
  posterUrl   String?

  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WatchlistItem {
  id          String @id @default(uuid())
  userId      String
  movieId     String
  status      WatchlistStatus @default(PLANNED)
  rating      Int?
  notes       String?
  createdAt   DateTime @default(now())
  upadatedAt  DateTime @default(now())
}

enum WatchlistStatus {
  PLANNED
  WATCHING
  COMPLETED
  DROPPED
}